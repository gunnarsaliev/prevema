DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# System Email Configuration (Resend)
# Used for system emails like password reset, user invitations, etc.
# IMPORTANT: Use a PRODUCTION Resend API key with a VERIFIED DOMAIN
# Test keys (onboarding@resend.dev) can only send to the account owner's email
RESEND_API_KEY=re_your_production_api_key_here
RESEND_DEFAULT_FROM_ADDRESS=noreply@yourdomain.com
RESEND_DEFAULT_FROM_NAME=Prevema

# Note: Organizations can configure their own Resend keys in the admin panel
# for custom branded emails (see Organizations > Email Configuration)

# Cloudflare R2 Storage Configuration
# Used for storing media files (images, documents, etc.)
S3_BUCKET=your-r2-bucket-name
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
# Public URL for R2 bucket (required for production)
# Use your R2.dev subdomain or custom domain (e.g., https://pub-xxxxx.r2.dev or https://cdn.yourdomain.com)
S3_PUBLIC_URL=https://pub-xxxxx.r2.dev
